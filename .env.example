# Local development: sqlite:///./ecommerce_local.db
# Production/Supabase: replace with the provider-issued PostgreSQL connection URL.
APP_ENV=development
DATABASE_URL=sqlite:///./ecommerce_local.db
# Local SQLite only. Keep false for Supabase/production and run Alembic migrations.
AUTO_CREATE_SCHEMA=false
REDIS_URL=redis://127.0.0.1:6379/0

SECRET_KEY=
# Comma-separated explicit API hostnames. Do not use *.
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
JWT_EXPIRE_MINUTES=60
JWT_ISSUER=ecommerce-affiliate-api
JWT_AUDIENCE=
# Google OAuth Web client ID. Use the same value for backend verification and frontend GIS.
GOOGLE_CLIENT_ID=
VNPAY_HASH_SECRET=
VNPAY_TMN_CODE=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNPAY_API_IP_ADDRESS=127.0.0.1
VNPAY_RETURN_URL=http://localhost:8000/api/orders/vnpay-return
VNPAY_IPN_URL=http://localhost:8000/api/orders/vnpay-ipn
VNPAY_PAYMENT_EXPIRY_MINUTES=15
VNPAY_REQUEST_TIMEOUT_SECONDS=10
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
TRUST_PROXY_HEADERS=false
ENABLE_HSTS=false
REQUIRE_REDIS_RATE_LIMIT=true

# Enable only when the selected VNPay flow is ready for use.
VNPAY_ENABLED=false
# Local development only. Keep this false in production.
VNPAY_MOCK_ENABLED=false
CUSTOMER_APP_URL=http://localhost:5173

GHN_TOKEN=
GHN_SHOP_ID=
GHN_API_URL=https://dev-online-gateway.ghn.vn/shiip/public-api
GHN_SHOP_DISTRICT_ID=
GHN_SHOP_WARD_CODE=
GHN_SHOP_NAME=
GHN_SHOP_PHONE=
GHN_SHOP_ADDRESS=
GHN_SHOP_WARD_NAME=
GHN_SHOP_DISTRICT_NAME=
GHN_SHOP_PROVINCE_NAME=

SEED_ADMIN_PASSWORD=
SEED_AFFILIATE_PASSWORD=

# Frontend production build variables (used by compose.production.yml).
VITE_API_URL=http://localhost:8000
VITE_CUSTOMER_APP_URL=http://localhost:5173
VITE_GOOGLE_CLIENT_ID=
