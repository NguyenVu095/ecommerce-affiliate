# Copy to .env.production and replace every example value before deployment.
APP_ENV=production
DATABASE_URL=postgresql://app_user:replace-me@db.example.com:5432/ecommerce
AUTO_CREATE_SCHEMA=false
REDIS_URL=redis://redis:6379/0

SECRET_KEY=
ALLOWED_HOSTS=api.example.com
JWT_EXPIRE_MINUTES=60
JWT_ISSUER=ecommerce-affiliate-api
JWT_AUDIENCE=ecommerce-web
GOOGLE_CLIENT_ID=
ALLOWED_ORIGINS=https://shop.example.com,https://admin.example.com,https://affiliate.example.com
TRUST_PROXY_HEADERS=true
ENABLE_HSTS=true
REQUIRE_REDIS_RATE_LIMIT=true

# Enable after registering the public IPN URL with VNPay and completing staging verification.
VNPAY_ENABLED=false
# Required when VNPAY_ENABLED=true. Sandbox and mock payment are rejected.
VNPAY_TMN_CODE=
VNPAY_URL=https://pay.vnpay.vn/vpcpay.html
VNPAY_API_URL=https://merchant.vnpay.vn/merchant_webapi/api/transaction
# Public outbound IP registered/allowlisted with VNPay.
VNPAY_API_IP_ADDRESS=
VNPAY_RETURN_URL=https://api.example.com/api/orders/vnpay-return
VNPAY_IPN_URL=https://api.example.com/api/orders/vnpay-ipn
VNPAY_PAYMENT_EXPIRY_MINUTES=15
VNPAY_REQUEST_TIMEOUT_SECONDS=10
VNPAY_HASH_SECRET=
VNPAY_MOCK_ENABLED=false
CUSTOMER_APP_URL=https://shop.example.com

GHN_TOKEN=
GHN_SHOP_ID=
GHN_API_URL=https://online-gateway.ghn.vn/shiip/public-api
GHN_SHOP_DISTRICT_ID=
GHN_SHOP_WARD_CODE=
GHN_SHOP_NAME=
GHN_SHOP_PHONE=
GHN_SHOP_ADDRESS=
GHN_SHOP_WARD_NAME=
GHN_SHOP_DISTRICT_NAME=
GHN_SHOP_PROVINCE_NAME=

VITE_API_URL=https://api.example.com
VITE_CUSTOMER_APP_URL=https://shop.example.com
VITE_GOOGLE_CLIENT_ID=
